# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.pyz
venv/
.venv/
env/
*.egg-info/
dist/
build/

# Logs
*.log
logs/

# Environment
.env
.env.*

# Claude Code (private conversation history and memory)
.claude/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Next.js (handled by schemestealer-react/.gitignore but belt-and-suspenders)
.next/
node_modules/

# Misc
*.pem
api.log

# Scraper cache (regenerated on demand). The live scrapers write .source_cache/;
# .scrape_cache/ is kept for any legacy local dirs.
.scrape_cache/
.source_cache/

# Local ML/analytics capture (contains session ids, user-agents and free-text
# feedback incl. emails — must never be committed). Production uses Supabase.
python-api/data/

# Local reference material & archives — never publish (the swatch-source PDF
# lives here; OLS/ is a local-only archive of superseded docs).
Skills&rules/*.pdf
Skills&rules/*.zip
Skills&rules/OLS/

# Bundled external audit plugin — has its own git repo, must not be embedded.
frontend-design-audit/

# Regenerable accuracy-harness outputs (baseline_harness.json IS tracked and
# stays — it is the frozen reference the harness compares against).
python-api/harness_report.json
python-api/report_*.json
python-api/synthetic_scenes/
